	measure '% Smart' = ```
			
			VAR QtdTrocaSmart =
			    CALCULATE(
			        COUNTROWS('QUERY - Conclusão BUR'),
			        'QUERY - Conclusão BUR'[Tipo_Entrada] = "Smart"
			    )
			
			VAR EntradaASTTotal =
			    CALCULATE(
			        COUNTROWS('OS_Geral'),
			        ALLSELECTED('OS_Geral') -- ALLSELECTED respeita os filtros de data/segmentação do relatório
			    )
			
			RETURN
			DIVIDE(QtdTrocaSmart, EntradaASTTotal, 0)
			
			
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 1bfc3b5a-9798-425a-969c-2a44bfdc2af1

		changedProperty = IsHidden

	measure '% Tradicional' =
			
			VAR QtdTrocaTradicional =
			    CALCULATE(
			        COUNTROWS('QUERY - Conclusão BUR'),
			        'QUERY - Conclusão BUR'[Tipo_Entrada] = "Tradicional"
			    )
			
			VAR EntradaASTTotal =
			    CALCULATE(
			        COUNTROWS('OS_Geral'),
			        ALLSELECTED('OS_Geral')
			    )
			
			RETURN
			DIVIDE(QtdTrocaTradicional, EntradaASTTotal, 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 8df4e585-baeb-42bc-843d-f5a45031f33f

		changedProperty = IsHidden

	measure '% smart_saida' =
			
			VAR TipoSelecionado =
			    SELECTEDVALUE ( 'QUERY - Conclusão BUR'[Tipo_Saida] )
			
			VAR QtdSmart =
			    CALCULATE (
			        COUNTROWS ( 'QUERY - Conclusão BUR' ),
			        'QUERY - Conclusão BUR'[Tipo_Saida] = "Smart"
			    )
			
			VAR TotalGeral =
			    CALCULATE (
			        COUNTROWS ( 'QUERY - Conclusão BUR' ),
			        ALL ( 'QUERY - Conclusão BUR'[Tipo_Saida] )
			    )
			
			RETURN
			IF (
			    TipoSelecionado = "Trad",
			    0,
			    DIVIDE ( QtdSmart, TotalGeral, 0 )
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 6d3f7a3f-3d2e-4bb6-aa88-fc38f9fcf24e

		changedProperty = IsHidden

