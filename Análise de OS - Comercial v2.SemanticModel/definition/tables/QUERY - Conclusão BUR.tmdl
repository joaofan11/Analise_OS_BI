	column Marca_Saida =
			
			VAR Resultado_Parametro =
			    LOOKUPVALUE(
			        'Parametro Smarts'[Marca_SKU],
			        'Parametro Smarts'[REF_SMART],
			        'QUERY - Conclusão BUR'[NumRelogio_Sem_ND]
			    )
			
			VAR Resultado_OS =
			    LOOKUPVALUE(
			        'OS_Geral'[Marca],
			        'OS_Geral'[Referência],
			        'QUERY - Conclusão BUR'[NumRelogio_Sem_ND]
			    )
			
			RETURN
			    COALESCE(
			        Resultado_Parametro,
			        Resultado_OS
			    )
