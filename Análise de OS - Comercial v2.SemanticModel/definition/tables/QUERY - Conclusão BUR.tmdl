	measure Qtd_troca_Trad_saida =
			
			VAR TipoSelecionado =
			    SELECTEDVALUE ( 'QUERY - Conclusão BUR'[Tipo_Saida] )
			RETURN
			IF (
			    TipoSelecionado = "Smart",
			    0,
			    CALCULATE (
			        [Total_Entrada_OS],
			        'QUERY - Conclusão BUR'[Tipo_Saida] = "Trad"
			    )
			)
		formatString: 0
		lineageTag: 116dba9c-c9e4-46af-866c-8b96da3d1d2e

