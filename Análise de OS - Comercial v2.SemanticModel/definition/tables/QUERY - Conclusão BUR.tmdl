	column Tipo_Saida = ```
			
			VAR ValorBuscado =
			    IF (
			        ISBLANK ( 'QUERY - Conclusão BUR'[NumRelogio_Sem_ND] ),
			        LOOKUPVALUE (
			            'Parametro Smarts'[SMART?],
			            'Parametro Smarts'[REF_SMART],
			            'QUERY - Conclusão BUR'[REFERENCIA]
			        ),
			        LOOKUPVALUE (
			            'Parametro Smarts'[SMART?],
			            'Parametro Smarts'[REF_SMART],
			            'QUERY - Conclusão BUR'[NumRelogio_Sem_ND]
			        )
			    )
			RETURN
			IF (
			    ISBLANK ( ValorBuscado ),
			    "Tradicional",
			    ValorBuscado
			)
			
