	measure '% Prazo Excedido_Entrada' =
			
			VAR QtdPrazoExcedido =
			    CALCULATE (
			        COUNT ( 'QUERY - Conclusão BUR'[Tipo_Entrada] ),
			        'QUERY - Conclusão BUR'[Motivo Troca] = "PRAZO EXCEDIDO"
			    )
			
			VAR TotalPorTipo =
			    CALCULATE (
			        COUNT ( 'QUERY - Conclusão BUR'[Tipo_Entrada] ),
			        ALL ( 'QUERY - Conclusão BUR'[Motivo Troca] )
			    )
			
			RETURN
			DIVIDE ( QtdPrazoExcedido, TotalPorTipo, 0 )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 15592d2e-363c-4282-b5e7-d2f6dfd490ed

		changedProperty = IsHidden

	measure '% Falta de Peça_Entrada' =
			
			VAR QtdPrazoExcedido =
			    CALCULATE (
			        COUNT ( 'QUERY - Conclusão BUR'[Tipo_Entrada] ),
			        'QUERY - Conclusão BUR'[Motivo Troca] = "FALTA DE PECAS"
			    )
			
			VAR TotalPorTipo =
			    CALCULATE (
			        COUNT ( 'QUERY - Conclusão BUR'[Tipo_Entrada] ),
			        ALL ( 'QUERY - Conclusão BUR'[Motivo Troca] )
