	column Tipo_Corrigido = ```
			
			COALESCE(
			    LOOKUPVALUE(
			        'Parametro Smarts'[SMART?],
			        'Parametro Smarts'[REF_SMART], 
			        'Defeitos'[Referência]
			    ),
			    "Tradicional"
			)
			```
		lineageTag: 12334a4f-5722-4e48-b269-bec44ca9035d
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column Marca_check =
			
			VAR Resultado_Parametro =
			    LOOKUPVALUE(
			        'Parametro Smarts'[Marca_SKU],
			        'Parametro Smarts'[REF_SMART],
			        'Defeitos'[Referência]
			    )
			
			VAR Resultado_OS =
			    LOOKUPVALUE(
			        'OS_Geral'[Marca],
			        'OS_Geral'[Referência],
			        'Defeitos'[Referência]
			    )
			
			RETURN
			    COALESCE(
			        Resultado_Parametro,
			        Resultado_OS
			    )
		lineageTag: 9daa8d40-4d17-4746-895b-df93e140029e
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

