		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'Data Saida' =
			
			IF(
			    ISBLANK(OS_Geral[DT_ENTRADA_BUR]),
			    DATEVALUE(OS_Geral[Data Status]),
			    DATEVALUE(OS_Geral[DT_ENTRADA_BUR])
			)
		formatString: General Date
		lineageTag: f3429e9b-17ac-47a1-931a-ef4d6cbf5a82
