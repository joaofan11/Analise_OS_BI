		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'LT Conserto_Concluido' =
			
			IF(
			    OS_Geral[StatusAtual] = "Concluido",
			    DATEDIFF( OS_Geral[Datade entrada], OS_Geral[Data Saida], DAY ),
			    BLANK()
			)
		formatString: 0
		lineageTag: 79351d55-93cf-4724-b75d-51f6818587d5
		summarizeBy: sum

