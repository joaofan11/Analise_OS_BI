	column Flag_Check_OS =
			
			IF(
			    'OS_Geral'[Marca_Check_OS] <> "Blanz",
			    1,
			    0
			)
		formatString: 0
		lineageTag: d0a48e4e-e0e4-48fd-9fa1-acdadf851454
		summarizeBy: sum

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'Familia Smart' = IF('OS_Geral'[Tipo_Entrada_OS_Geral]="Smart",LOOKUPVALUE('Parametro Smarts'[Familia_SKU],'Parametro Smarts'[REF_SMART],'OS_Geral'[Referência]),"Tradicional")
		lineageTag: d5aae9f8-4607-425a-8b86-d40cc8670fde
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column DEFEITO =
			
			VAR Defeito = MINX (FILTER ( Defeitos, Defeitos[OS] = OS_Geral[OS] ),Defeitos[DescriçãoDefeito])
			
			RETURN
			
			IF(Defeito=BLANK(),"Não Preenchido",Defeito)
		lineageTag: 206ba6aa-cb6b-448a-aff0-31a569823c57
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'LT Conserto' = DATEDIFF('OS_Geral'[Datade entrada],OS_Geral[Data Saida],DAY)
		formatString: 0
		lineageTag: 23d55160-4c1f-4f76-a94b-456610328fc9
