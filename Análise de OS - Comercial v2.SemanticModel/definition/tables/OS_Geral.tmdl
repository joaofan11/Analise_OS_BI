	column Tipo_Entrada_OS_Geral = ```
			
			COALESCE(
			    LOOKUPVALUE(
			        'Parametro Smarts'[SMART?],
			        'Parametro Smarts'[REF_SMART], 
			        'OS_Geral'[Referência]
			    ),
			    "Tradicional"
			)
			```
		lineageTag: 3ec53044-e993-4975-8f6a-79e7f217af0e
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column Marca_Check_OS =
			
			VAR Resultado_Parametro =
			    LOOKUPVALUE(
			        'Parametro Smarts'[Marca_SKU],
			        'Parametro Smarts'[REF_SMART],
			        'OS_Geral'[Referência]
			    )
			
			VAR Resultado_OS =
			    LOOKUPVALUE(
			        'OS_Geral'[Marca],
			        'OS_Geral'[Referência],
			        'OS_Geral'[Referência]
			    )
			
			RETURN
			    COALESCE(
			        Resultado_Parametro,
			        Resultado_OS
			    )
		lineageTag: daacd713-dc9f-4087-ae6f-ffa5f3c3aae3
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column Defeitos =
			
			COALESCE(
			    LOOKUPVALUE(
			        Defeitos[DescriçãoDefeito],
			        Defeitos[OS],
			        'OS_Geral'[OS]
			    ),
			    "Não Preenchido"
			)
		lineageTag: e083dd3a-63bd-47c1-b9ed-e363e517dfc5
