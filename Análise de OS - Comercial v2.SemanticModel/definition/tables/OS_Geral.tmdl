	column DT_ENTRADA_BUR =
			LOOKUPVALUE(
			    'Backlog BUR'[DT ENTRADA], 'Backlog BUR'[ORD SERV IMP], OS_Geral[OS])
		formatString: General Date
		lineageTag: 1f7b0a25-7c94-4779-a139-09b9f530ee5e
