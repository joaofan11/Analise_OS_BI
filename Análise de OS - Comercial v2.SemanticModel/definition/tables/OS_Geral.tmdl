table OS_Geral
	lineageTag: 25ef1f7f-7661-46cd-9024-fe5b30208a10

	measure Total_OS = COUNTROWS(FILTER('OS_Geral','OS_Geral'[OS]<>BLANK()))
		formatString: 0
		lineageTag: 75889d1f-c33d-407a-9fdf-73a416bf0d77

		changedProperty = IsHidden

	measure Qtd_entrada_Trad =
			
			VAR EntradaSelecionada =
			    SELECTEDVALUE ( 'OS_Geral'[Tipo_Entrada_OS_Geral] )
			RETURN
			    IF (
			        EntradaSelecionada = "Smart",
			        0,
			        CALCULATE (
			            [Total_OS],
			            'OS_Geral'[Tipo_Entrada_OS_Geral] = "Trad"
			        )
			    )
		formatString: 0
		lineageTag: 9fc4b862-99d5-4e13-913e-dc5ef5cee967

		changedProperty = IsHidden

	measure %_conc_smart =
			
			DIVIDE(
			    [Qtd_entrada_Trad],
			    [Total_OS]
			)
		lineageTag: 8e13f1f7-a6aa-48f7-a9cb-7f0d0780f171

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure total_cliente =
			
			CALCULATE(
			    COUNT('OS_Geral'[Garantia Fora Estoque]),
			    'OS_Geral'[Garantia Fora Estoque] = "Estoque Cliente"
			)
		formatString: 0
		lineageTag: fa5e29d4-a164-4184-904a-c261513d7634

		changedProperty = IsHidden

	measure total_garantia =
			
			CALCULATE(
			    COUNT('OS_Geral'[Garantia Fora Estoque]),
			    'OS_Geral'[Garantia Fora Estoque] = "Garantia de Venda"
			)
		formatString: 0
		lineageTag: 6efdc266-e703-4466-a7d8-0ca36debbe9d

		changedProperty = IsHidden

	measure Qtd_entrada_Smart =
			
			VAR EntradaSelecionada =
			    SELECTEDVALUE ( 'OS_Geral'[Tipo_Entrada_OS_Geral] )
			RETURN
			    IF (
			        EntradaSelecionada = "Trad",
			        0,
			        CALCULATE (
			            [Total_OS],
			            'OS_Geral'[Tipo_Entrada_OS_Geral] = "Smart"
			        )
			    )
		formatString: 0
		lineageTag: cff20b74-ed7d-4427-8121-1606d7d614c3

		changedProperty = IsHidden

	measure Qtd_tipo_trad =
			
			CALCULATE(
			    [Total_OS],
			    'OS_Geral'[Tipo_Entrada_OS_Geral] = "Tradicional"
			)
		formatString: 0
		lineageTag: e542f88c-3a88-4a93-b13d-054386d8103c

		changedProperty = IsHidden

	measure 'Percentual de Trocas' = ```
			
			DIVIDE(
			    SUM('QUERY - Conclusão BUR'[Flag_Check_BUR]),
			    SUM('OS_Geral'[Flag_Check_OS])
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 6dddaea2-fbae-4ebf-b508-6a22a7e06a55

		changedProperty = IsHidden

	measure 'Percentual de entrada_vendas' =
			
			DIVIDE(
			    SUM('OS_Geral'[Flag_Check_OS]),
			    SUM('Vendas'[QTDADE])
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 1269fe85-c990-42d4-8d42-f89c4fa6d739

		changedProperty = IsHidden

	measure 'Entrada AST teste 2' = ```
			
			CALCULATE(
			    SUM(OS_Geral[Flag_Check_OS]),
			    
			    -- Propaga o filtro de SEGMENTAÇÃO corretamente
			    TREATAS(
			        VALUES('QUERY - Conclusão BUR'[SEGMENTACAO]),
			        OS_Geral[Garantia Fora Estoque]
			    ),
			
			    -- REMOVE APENAS as colunas que causam interferência
			    REMOVEFILTERS('QUERY - Conclusão BUR'[SEGMENTACAO])
			)
			```
		formatString: 0
		lineageTag: 3d9fb697-e829-482d-bef4-dc7b4301f1dd

		changedProperty = IsHidden

	measure 'Entrada troca teste 2' = ```
			
			CALCULATE(
			    SUM('QUERY - Conclusão BUR'[Flag_Check_BUR]),
			    
			    -- Propaga o filtro de SEGMENTAÇÃO corretamente
			    TREATAS(
			        VALUES('OS_Geral'[Garantia Fora Estoque]),
			        'QUERY - Conclusão BUR'[SEGMENTACAO]
			    ),
			
			    -- REMOVE APENAS as colunas que causam interferência
			    REMOVEFILTERS('QUERY - Conclusão BUR'[SEGMENTACAO])
			)
			```
		formatString: 0
		lineageTag: cea52391-f8f9-49d0-9db0-164686b80290

		changedProperty = IsHidden

	measure TaxaTroca =
			
			VAR TotalTroca =
			    CALCULATE(
			        COUNTROWS('QUERY - Conclusão BUR'),
			        'QUERY - Conclusão BUR'[Flag_Check_BUR] = 1
			    )
			
			VAR Concluido =
			    CALCULATE(
			        COUNTROWS(OS_geral),
			        OS_geral[statusAtual] = "CONCLUIDO",
			        USERELATIONSHIP(Calendario[Date], OS_geral[Data Status])
			    )
			
			RETURN
			DIVIDE( TotalTroca, TotalTroca + Concluido )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 17327f38-82b9-4057-969b-1a2022fb03aa

		changedProperty = IsHidden

	measure Divisor =
			
			VAR TotalTroca =
			    CALCULATE(
			        COUNTROWS('QUERY - Conclusão BUR'),
			        'QUERY - Conclusão BUR'[Flag_Check_BUR] = 1
			    )
			
			VAR Concluido =
			    CALCULATE(
			        COUNTROWS(OS_geral),
			        OS_geral[statusAtual] = "CONCLUIDO",
			        USERELATIONSHIP(Calendario[Date], OS_geral[Data Status])
			    )
			
			RETURN
			TotalTroca + Concluido
		formatString: 0
		lineageTag: 38a1453e-b046-473c-a591-35eef41ea0c0

		changedProperty = IsHidden

	measure 'OS Concluídas Mês' =
			
			CALCULATE(
			    COUNTROWS('OS_Geral'),
			    USERELATIONSHIP(Calendario[Date], 'OS_Geral'[Data Status])
			)
		lineageTag: fe7277c2-51a6-4f5c-b9ed-3bf379ecef68

		changedProperty = IsHidden

